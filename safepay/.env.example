# ─────────────────────────────────────────────────────────────────────────────
#  Trujillo SafePay PRO — Variables de entorno
#  Copia este archivo como .env y rellena los valores reales.
#  NUNCA subas .env a git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de datos ─────────────────────────────────────────────────────────────
# PostgreSQL (producción Render):
#   DATABASE_URL=postgresql://user:password@host:5432/safepay_db
# SQLite local (dejar vacío para usar SQLite automáticamente):
DATABASE_URL=

# ── Pasarela de pago ──────────────────────────────────────────────────────────
# Opciones: stripe | manual
PAYMENT_PROVIDER=manual

# Stripe (obtener en https://dashboard.stripe.com/apikeys)
PAYMENT_SECRET_KEY=TU_STRIPE_SECRET_KEY_AQUI
PAYMENT_PUBLIC_KEY=TU_STRIPE_PUBLIC_KEY_AQUI

# Stripe Webhook Secret (obtener en Dashboard → Webhooks → tu endpoint)
WEBHOOK_SECRET=TU_WEBHOOK_SECRET_AQUI

# ── Servidor ──────────────────────────────────────────────────────────────────
# URL pública de SafePay (para generar success_url/cancel_url de Stripe)
BASE_URL=http://127.0.0.1:5001

# Puerto local
PORT=5001

# Clave secreta de Flask (genera una larga y aleatoria para producción)
SECRET_KEY=cambia-esto-por-una-clave-segura-larga

# ── CORS ──────────────────────────────────────────────────────────────────────
# URLs permitidas para llamar la API (separadas por coma)
# En producción: URL pública de tu instancia LCA PRO en Render
ALLOWED_ORIGINS=http://127.0.0.1:5050,http://localhost:5050
