# ============================================================
# Variables de entorno necesarias para el backend (Render / Railway / local)
# Copia este archivo como .env para desarrollo local
# En Render: configúralas en Settings > Environment Variables
# ============================================================

# --- IMÁGENES (Cloudinary) --- OBLIGATORIO en producción ---
# Sin esto, las imágenes se guardan en disco local y se PIERDEN al reiniciar
# Obtén tu URL en: https://console.cloudinary.com/
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# --- BASE DE DATOS (Render Disk) ---
# Monta un disco persistente en Render y pon aquí su ruta
# En Render: Settings > Disks > Mount Path (ej: /var/data)
DATA_DIR=/var/data

# --- DIRECTORIO DE UPLOADS LOCAL (opcional si usas Cloudinary) ---
# UPLOAD_DIR=/var/data/uploads

# --- GEMINI (Google AI) ---
GEMINI_API_KEY=tu_clave_de_gemini_aqui
GEMINI_MODEL=gemini-2.5-flash
